# AudienceResonanceAnalyzer Environment Variables

# ===========================================
# REQUIRED - Core API Keys
# ===========================================

# OpenAI API Key for AI-powered analysis
OPENAI_API_KEY=sk-...

# ===========================================
# OPTIONAL - PowerPoint Export Feature
# ===========================================

# Supabase Configuration (for React state bridge)
# Get these from: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Screenshot Service - Choose ONE:

# Option 1: Browserless.io (Recommended, $29/mo)
# Get API key from: https://browserless.io
BROWSERLESS_API_KEY=your-browserless-api-key
BROWSERLESS_URL=https://chrome.browserless.io

# Option 2: ScreenshotAPI.net (Pay-per-use alternative)
# Get API key from: https://screenshotapi.net
# SCREENSHOT_API_KEY=your-screenshot-api-key

# App URL (needed for screenshot service to access React components)
# Set this to your deployed app URL
APP_URL=https://your-app-url.repl.co

# ===========================================
# OPTIONAL - OpenX Audience Activation
# ===========================================

# OpenX OpenAudience API (for automated audience creation)
OPENX_API_KEY=
OPENX_API_URL=https://api.openx.com/oa/graphql
OPENX_PROVIDER_ID=

# OpenX Audience & Deal Naming
OPENX_AUDIENCE_NAME_PREFIX=Digital Culture Group
OPENX_DEAL_ID_PREFIX=DCG-

# OpenX Deal Auto-Creation (defaults match existing DCG deal config)
OPENX_DEAL_CURRENCY=USD
OPENX_DEAL_PRICE=0.01
OPENX_DEAL_PMP_TYPE=3
OPENX_DEAL_DEMAND_PARTNER=537073301
OPENX_DEAL_FEES_PARTNER_ID=561460270
OPENX_DEAL_FEES_SHARE=0.300

# ===========================================
# OPTIONAL - Other Features
# ===========================================

# Twilio (for SMS notifications, if enabled)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
